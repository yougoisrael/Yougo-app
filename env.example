# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Yougo v2 — Environment Variables
#  1. انسخ هذا الملف → .env
#  2. أدخل قيمك الحقيقية
#  3. لا ترفع .env على GitHub ابداً!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Supabase (Auth + Database)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_ADMIN_EMAIL=admin@yougo.app

# Cloudflare Worker (Cache)
VITE_WORKER_URL=https://yougo-cache.YOUR_NAME.workers.dev

# Cloudflare R2 (صور)
VITE_R2_PUBLIC_URL=https://assets.yougo.app
VITE_R2_UPLOAD_ENDPOINT=https://yougo-r2.YOUR_NAME.workers.dev
VITE_R2_UPLOAD_TOKEN=your_r2_token_here

# Firebase FCM (اشعارات)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key
